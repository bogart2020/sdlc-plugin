name: SDLC CI — {{PROJECT_NAME}}

on:
  push:
    branches: [main, master, develop]
  pull_request:
    branches: [main, master, develop]

jobs:
  quality:
    name: Lint, Test & Build
    runs-on: ubuntu-latest

    strategy:
      matrix:
        node-version: ['20.x']

    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Set up Node.js ${{ matrix.node-version }}
        uses: actions/setup-node@v4
        with:
          node-version: ${{ matrix.node-version }}
          cache: '{{PACKAGE_MANAGER}}'

      - name: Install dependencies
        run: {{INSTALL_CMD}}

      # The orchestrator removes the Lint and/or Build steps if the
      # corresponding command is "none". Never leave a step that runs `none`.
      - name: Lint
        run: {{LINT_CMD}}

      - name: Test
        run: {{TEST_CMD}}

      - name: Build
        run: {{BUILD_CMD}}

  security:
    name: Security scan
    runs-on: ubuntu-latest

    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Set up Node.js
        uses: actions/setup-node@v4
        with:
          node-version: '20.x'
          cache: '{{PACKAGE_MANAGER}}'

      - name: Install dependencies
        run: {{INSTALL_CMD}}

      - name: Dependency audit
        run: {{AUDIT_CMD}}
        continue-on-error: false

      - name: Secret scan
        uses: trufflesecurity/trufflehog@main
        with:
          path: ./
          extra_args: --only-verified
